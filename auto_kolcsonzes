from abc import ABC, abstractmethod
from datetime import datetime, date


class Auto(ABC):
    """Absztrakt autó osztály, amely az autók közös adatait kezeli."""

    def __init__(self, rendszam: str, tipus: str, berleti_dij: int):
        self.__rendszam = rendszam
        self.__tipus = tipus
        self.__berleti_dij = berleti_dij

    @property
    def rendszam(self):
        return self.__rendszam

    @property
    def tipus(self):
        return self.__tipus

    @property
    def berleti_dij(self):
        return self.__berleti_dij

    @berleti_dij.setter
    def berleti_dij(self, ertek: int):
        if ertek <= 0:
            raise ValueError("A bérleti díj csak pozitív szám lehet!")
        self.__berleti_dij = ertek

    @abstractmethod
    def auto_adatok(self):
        pass

    def __str__(self):
        return f"{self.rendszam} - {self.tipus} - {self.berleti_dij} Ft/nap"


class Szemelyauto(Auto):
    """Személyautó osztály."""

    def __init__(self, rendszam: str, tipus: str, berleti_dij: int, ferohelyek_szama: int):
        super().__init__(rendszam, tipus, berleti_dij)
        self.__ferohelyek_szama = ferohelyek_szama

    @property
    def ferohelyek_szama(self):
        return self.__ferohelyek_szama

    def auto_adatok(self):
        return f"Személyautó | {self} | Férőhelyek: {self.ferohelyek_szama}"


class Teherauto(Auto):
    """Teherautó osztály."""

    def __init__(self, rendszam: str, tipus: str, berleti_dij: int, teherbiras_kg: int):
        super().__init__(rendszam, tipus, berleti_dij)
        self.__teherbiras_kg = teherbiras_kg

    @property
    def teherbiras_kg(self):
        return self.__teherbiras_kg

    def auto_adatok(self):
        return f"Teherautó | {self} | Teherbírás: {self.teherbiras_kg} kg"


class Berles:
    """Egy autó egy adott napra történő bérlését tárolja."""

    def __init__(self, auto: Auto, datum: date, berlo_neve: str):
        self.__auto = auto
        self.__datum = datum
        self.__berlo_neve = berlo_neve

    @property
    def auto(self):
        return self.__auto

    @property
    def datum(self):
        return self.__datum

    @property
    def berlo_neve(self):
        return self.__berlo_neve

    def __str__(self):
        return f"{self.berlo_neve} | {self.auto.rendszam} - {self.auto.tipus} | {self.datum} | Ár: {self.auto.berleti_dij} Ft"


class Autokolcsonzo:
    """Az autókölcsönző kezeli az autókat és az aktuális bérléseket."""

    def __init__(self, nev: str):
        self.__nev = nev
        self.__autok = []
        self.__berlesek = []

    @property
    def nev(self):
        return self.__nev

    @property
    def autok(self):
        return self.__autok

    @property
    def berlesek(self):
        return self.__berlesek

    def auto_hozzaadasa(self, auto: Auto):
        self.__autok.append(auto)

    def auto_kereses(self, rendszam: str):
        for auto in self.__autok:
            if auto.rendszam.lower() == rendszam.lower():
                return auto
        return None

    def berles_letezik(self, rendszam: str, datum: date):
        for berles in self.__berlesek:
            if berles.auto.rendszam.lower() == rendszam.lower() and berles.datum == datum:
                return berles
        return None

    def auto_berlese(self, rendszam: str, datum: date, berlo_neve: str):
        auto = self.auto_kereses(rendszam)

        if auto is None:
            raise ValueError("Nincs ilyen rendszámú autó a kölcsönzőben!")

        if datum < date.today():
            raise ValueError("Múltbeli dátumra nem lehet autót bérelni!")

        if self.berles_letezik(rendszam, datum):
            raise ValueError("Ez az autó ezen a napon már ki van bérelve!")

        uj_berles = Berles(auto, datum, berlo_neve)
        self.__berlesek.append(uj_berles)
        return auto.berleti_dij

    def berles_lemondasa(self, rendszam: str, datum: date):
        berles = self.berles_letezik(rendszam, datum)

        if berles is None:
            raise ValueError("Nem található ilyen bérlés, ezért nem lehet lemondani!")

        self.__berlesek.remove(berles)
        return True

    def autok_listazasa(self):
        if not self.__autok:
            print("Nincs autó a rendszerben.")
            return

        print("\nElérhető autók a kölcsönzőben:")
        for auto in self.__autok:
            print("- " + auto.auto_adatok())

    def berlesek_listazasa(self):
        if not self.__berlesek:
            print("\nJelenleg nincs aktív bérlés.")
            return

        print("\nAktuális bérlések:")
        for index, berles in enumerate(self.__berlesek, start=1):
            print(f"{index}. {berles}")


def datum_bekerese():
    datum_szoveg = input("Add meg a bérlés dátumát (ÉÉÉÉ-HH-NN): ")
    try:
        return datetime.strptime(datum_szoveg, "%Y-%m-%d").date()
    except ValueError:
        raise ValueError("Hibás dátumformátum! Helyes forma: ÉÉÉÉ-HH-NN, például 2026-05-25")


def kezdeti_adatok_betoltese():
    kolcsonzo = Autokolcsonzo("Andris Autókölcsönző")

    auto1 = Szemelyauto("ABC-123", "Toyota Corolla", 15000, 5)
    auto2 = Szemelyauto("DEF-456", "Volkswagen Golf", 18000, 5)
    auto3 = Teherauto("GHI-789", "Ford Transit", 28000, 1200)

    kolcsonzo.auto_hozzaadasa(auto1)
    kolcsonzo.auto_hozzaadasa(auto2)
    kolcsonzo.auto_hozzaadasa(auto3)

    # 4 előre betöltött bérlés, ahogy a feladat kéri
    kolcsonzo.auto_berlese("ABC-123", date(2026, 5, 25), "Kovács Péter")
    kolcsonzo.auto_berlese("DEF-456", date(2026, 5, 26), "Nagy Anna")
    kolcsonzo.auto_berlese("GHI-789", date(2026, 5, 27), "Szabó Gábor")
    kolcsonzo.auto_berlese("ABC-123", date(2026, 5, 28), "Tóth Erika")

    return kolcsonzo


def menu_megjelenites():
    print("\n===== AUTÓKÖLCSÖNZŐ RENDSZER =====")
    print("1. Autók listázása")
    print("2. Autó bérlése")
    print("3. Bérlés lemondása")
    print("4. Bérlések listázása")
    print("0. Kilépés")


def main():
    kolcsonzo = kezdeti_adatok_betoltese()
    print(f"Üdvözöllek a(z) {kolcsonzo.nev} rendszerében!")

    while True:
        menu_megjelenites()
        valasztas = input("Válassz egy menüpontot: ")

        try:
            if valasztas == "1":
                kolcsonzo.autok_listazasa()

            elif valasztas == "2":
                kolcsonzo.autok_listazasa()
                rendszam = input("Add meg a bérelni kívánt autó rendszámát: ")
                datum = datum_bekerese()
                berlo_neve = input("Add meg a bérlő nevét: ")

                if not berlo_neve.strip():
                    raise ValueError("A bérlő neve nem lehet üres!")

                ar = kolcsonzo.auto_berlese(rendszam, datum, berlo_neve)
                print(f"Sikeres bérlés! Fizetendő ár: {ar} Ft")

            elif valasztas == "3":
                kolcsonzo.berlesek_listazasa()
                rendszam = input("Add meg a lemondandó bérlés autójának rendszámát: ")
                datum = datum_bekerese()
                kolcsonzo.berles_lemondasa(rendszam, datum)
                print("A bérlés sikeresen lemondva!")

            elif valasztas == "4":
                kolcsonzo.berlesek_listazasa()

            elif valasztas == "0":
                print("Kilépés a rendszerből. Viszlát!")
                break

            else:
                print("Érvénytelen menüpont! Kérlek, válassz újra.")

        except ValueError as hiba:
            print(f"Hiba: {hiba}")
        except Exception as hiba:
            print(f"Váratlan hiba történt: {hiba}")


if __name__ == "__main__":
    main()
